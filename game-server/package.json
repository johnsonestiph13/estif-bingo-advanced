{
  "name": "estif-bingo-advanced",
  "version": "4.0.0",
  "description": "Estif Bingo 24/7 - Advanced Multiplayer Bingo Game with 1000 Cartelas",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:watch": "nodemon --watch server.js --watch src --watch data server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate-cartelas": "node scripts/generateCartelas.js",
    "migrate": "node scripts/runMigrations.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "bingo",
    "multiplayer",
    "game",
    "socketio",
    "telegram",
    "postgresql",
    "realtime",
    "websocket",
    "gambling",
    "etb"
  ],
  "author": "Estifanos Yhannis",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.1"
  },
  "nodemonConfig": {
    "ignore": [
      "data/*.json",
      "logs/*.log",
      "node_modules"
    ],
    "watch": [
      "server.js",
      "src/",
      "public/"
    ],
    "ext": "js,json,html,css",
    "delay": 1000
  }
}
