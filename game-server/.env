# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Security
JWT_SECRET=your_super_secret_key_change_this
API_SECRET=shared_secret_with_telegram_bot

# Admin
ADMIN_EMAIL=admin@estif.com
ADMIN_PASSWORD_HASH=$2b$10$...

# Bot API
BOT_API_URL=https://your-telegram-bot.onrender.com

# Game Settings (Optional)
SELECTION_TIME=50
DRAW_INTERVAL=4000
NEXT_ROUND_DELAY=6000
BET_AMOUNT=10
MAX_CARTELAS=2
TOTAL_CARTELAS=400

# Environment
NODE_ENV=production
PORT=3000

# Migration Control (set to true to skip auto migrations)
MANUAL_MIGRATION=false