# ==================== REQUIRED ====================
# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin Telegram User ID (your personal ID)
ADMIN_CHAT_ID=123456789

# PostgreSQL Database URL
DATABASE_URL=postgresql://username:password@host:5432/database_name

# JWT Secret (must match game server)
JWT_SECRET=your_jwt_secret_here_min_32_chars

# API Secret (must match game server - shared secret)
API_SECRET=your_api_secret_here_min_32_chars

# ==================== OPTIONAL ====================
# Flask API Port
FLASK_PORT=8080

# Game Web URL
GAME_WEB_URL=https://estif-bingo-247.onrender.com/player.html

# Support Links
SUPPORT_GROUP_LINK=https://t.me/your_group
SUPPORT_CHANNEL_LINK=https://t.me/your_channel

# Payment Accounts
CBE_ACCOUNT=1000179576997
ABBISINIYA_ACCOUNT=35241051
TELEBIRR_ACCOUNT=0987713787
MPESA_ACCOUNT=0722345146
ACCOUNT_HOLDER=Estifanos Yhannis

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# Database Pool
DB_MIN_SIZE=5
DB_MAX_SIZE=20
DB_COMMAND_TIMEOUT=60

# Migration Control
SKIP_AUTO_MIGRATIONS=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Rate Limiting
MAX_OTP_REQUESTS=3
MAX_DEPOSIT_REQUESTS=5
MAX_CASHOUT_REQUESTS=3
RATE_LIMIT_WINDOW=300