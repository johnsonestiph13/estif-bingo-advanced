# ==================== SERVER CONFIGURATION ====================
# Flask API Port (for Render: use 10000)
FLASK_PORT=10000

# Alternative port variable
PORT=10000

# Host address (0.0.0.0 for production)
HOST=0.0.0.0

# Environment (production, development, staging)
