# JWT algorithm
JWT_ALGORITHM=HS256

# ==================== SESSION SETTINGS ====================
# Admin session expiry (e.g., 24h, 7d)
ADMIN_SESSION_EXPIRY=24h

# Player session expiry (e.g., 30m, 2h)
PLAYER_SESSION_EXPIRY=30m

# ==================== PYTHON VERSION ====================
PYTHON_VERSION=3.11.0

# ==================== TEST VARIABLES ====================
# For testing purposes only
TEST_VAR=hello

# ==================== NOTES ====================
# 1. Never commit this file to version control
# 2. Add .env to .gitignore
# 3. Use .env.example as template for other developers
# 4. All boolean values should be true/false (lowercase)
# 5. For production, use strong secrets (min 32 chars)
# 6. Update URLs to match your deployed services