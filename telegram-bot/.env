# ==================== GAME CONSTANTS ====================
# Cartela price in ETB
CARTELA_PRICE=10

# Minimum balance required to play (ETB)
MIN_BALANCE_FOR_PLAY=10

# Maximum cartelas per player per round
MAX_CARTELAS=4

# Total cartela types available
TOTAL_CARTELAS=75

# Win percentage options (comma-separated)
WIN_PERCENTAGES=70,75,76,80

# Default win percentage
DEFAULT_WIN_PERCENTAGE=80

# ==================== GAME TIMING (milliseconds) ====================
# Cartela selection time (50 seconds = 50000ms)
SELECTION_TIME=50000

# Number draw interval (4 seconds = 4000ms)
DRAW_INTERVAL=4000

# Delay between rounds (6 seconds = 6000ms)
NEXT_ROUND_DELAY=6000

# ==================== SOUND & EFFECTS ====================
# Default sound pack for new players
DEFAULT_SOUND_PACK=pack1

# Available sound packs (comma-separated)
SOUND_PACKS=pack1,pack2,pack3,pack4

# ==================== SUPPORT LINKS ====================
# Telegram support channel link
SUPPORT_CHANNEL_LINK=https://t.me/temarineh

# Telegram support group link
SUPPORT_GROUP_LINK=https://t.me/presectionA

# ==================== DATABASE CONFIGURATION ====================
# Minimum database connections in pool
DB_MIN_SIZE=2

# Maximum database connections in pool
DB_MAX_SIZE=10

# Database command timeout (seconds)
DB_COMMAND_TIMEOUT=60

# Database connection timeout (milliseconds)
DB_CONNECTION_TIMEOUT=5000

# Database idle timeout (milliseconds)
DB_IDLE_TIMEOUT=30000

# Database pool max size
DB_POOL_MAX=20

# Skip auto migrations (true/false)
SKIP_AUTO_MIGRATIONS=false

# Manual migration mode (true/false)
MANUAL_MIGRATION=false

# ==================== LOGGING CONFIGURATION ====================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format string
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Log to file (true/false)
LOG_TO_FILE=false

# ==================== RATE LIMITING ====================
# Maximum OTP requests per window
MAX_OTP_REQUESTS=3

# Maximum deposit requests per window
MAX_DEPOSIT_REQUESTS=5

# Maximum cashout requests per window
MAX_CASHOUT_REQUESTS=3

# Maximum transfer requests per window
MAX_TRANSFER_REQUESTS=5

# Rate limit window (seconds)
RATE_LIMIT_WINDOW=300

# Game rate limit max requests per minute
GAME_RATE_LIMIT_MAX=30

# Auth rate limit max requests per 5 minutes
AUTH_RATE_LIMIT_MAX=5

