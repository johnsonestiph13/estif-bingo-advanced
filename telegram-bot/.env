# ==================== TRANSFER SETTINGS ====================
# Minimum transfer amount (ETB)
MIN_TRANSFER=1

# Maximum transfer amount per transaction (ETB)
MAX_TRANSFER=10000

# Daily transfer limit (ETB)
TRANSFER_DAILY_LIMIT=50000

# Transfer fee percentage (0 = no fee)
TRANSFER_FEE_PERCENTAGE=0

# ==================== WEBSOCKET SETTINGS ====================
# WebSocket ping interval (milliseconds)
WS_PING_INTERVAL=25000

# WebSocket ping timeout (milliseconds)
WS_PING_TIMEOUT=60000

# WebSocket reconnect delay (milliseconds)
WS_RECONNECT_DELAY=1000

# Maximum WebSocket reconnect attempts
